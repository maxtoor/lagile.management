# Django base
DJANGO_SECRET_KEY=change-me
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=Europe/Rome

# Identita applicazione e branding
AGILE_SITES=Sede principale
AGILE_DATE_DISPLAY_FORMAT=IT
AGILE_LOGIN_LOGO_URL=
AGILE_FAVICON_URL=
AGILE_COMPANY_NAME=LAgile.Management
AGILE_COPYRIGHT_YEAR=2026

# Logging applicativo e monitor log in admin
AGILE_LOG_FILE=/app/logs/agile.log
AGILE_LOG_LEVEL=INFO
AGILE_LOG_MONITOR_FILE=/app/logs/agile.log
# Formato: label:/path;label:/path
AGILE_LOG_MONITOR_SOURCES=app:/app/logs/agile.log;scheduler:/app/logs/scheduler.log
AGILE_LOG_MONITOR_REFRESH_SECONDS=8

# Funzioni legacy ICB
ICB_LEGACY=0

# Intervallo di controllo dello scheduler Docker, in secondi
REMINDER_CHECK_INTERVAL_SECONDS=86400

# PostgreSQL
POSTGRES_DB=agile_work
POSTGRES_USER=agile
POSTGRES_PASSWORD=agile
# Docker: db | installazione nativa: 127.0.0.1 o /tmp
POSTGRES_HOST=db
POSTGRES_PORT=5432

# LDAP
# LDAP_ENABLED=1 abilita autenticazione e import da directory LDAP
LDAP_ENABLED=0
LDAP_SERVER_URI=ldap://ldap.example.org:389
LDAP_BIND_DN=cn=svc_ldap,ou=svc,dc=example,dc=org
LDAP_BIND_PASSWORD=change-me
LDAP_USER_BASE_DN=ou=people,dc=example,dc=org
# Filtro di login: %(user)s viene sostituito con username inserito
LDAP_USER_FILTER=(uid=%(user)s)
LDAP_ATTR_USERNAME=uid
LDAP_ATTR_FIRST_NAME=givenName
LDAP_ATTR_LAST_NAME=sn
LDAP_ATTR_EMAIL=mail
LDAP_ATTR_DEPARTMENT=ou
# Filtro usato dai comandi di import e sync LDAP
LDAP_IMPORT_FILTER=(objectClass=person)

# Email
# Console backend utile in sviluppo; SMTP per ambienti reali
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.org
EMAIL_PORT=587
EMAIL_HOST_USER=mailer@example.org
EMAIL_HOST_PASSWORD=change-me
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
DEFAULT_FROM_EMAIL=noreply@example.org
AGILE_EMAIL_FROM_NAME=
# Se valorizzata, reindirizza tutte le email verso gli indirizzi indicati
AGILE_EMAIL_REDIRECT_TO=
# Base URL pubblica usata per generare link nelle email
AGILE_PUBLIC_BASE_URL=http://localhost:8001

# Bootstrap superuser automatico in Docker
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
